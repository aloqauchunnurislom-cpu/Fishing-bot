# Telegram Bot Token (BotFather dan olinadi)
BOT_TOKEN=your_bot_token_here

# Admin ID lar (vergul bilan ajratilgan)
ADMIN_IDS=123456789,987654321

# API kalitlar (ixtiyoriy — bo'lmasa o'tkazib yuboriladi)
VIRUSTOTAL_API_KEY=
GOOGLE_SAFE_BROWSING_KEY=
IPQS_API_KEY=

# Cache sozlamalari
CACHE_TTL=86400
CACHE_MAX_SIZE=2000

# Redirect
MAX_REDIRECTS=8

# Scorer
AUTO_DELETE_THRESHOLD=90
STRICT_MODE_THRESHOLD=87

# CSV yangilash (soatda)
CSV_UPDATE_INTERVAL_HOURS=6

# Queue
MAX_PARALLEL_CHECKS=5
CHECK_TIMEOUT=30
